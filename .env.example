# Copy to .env and fill in values.

# Required unless DEMO_MODE=true
DEEPINFRA_API_KEY=

# Defaults shown.
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Set to true to run end-to-end without any DeepInfra calls.
# The app will serve a pre-seeded mock brief and the generate flow
# returns the same mock after a short simulated delay.
DEMO_MODE=true

# Application timezone for IST date arithmetic.
TIMEZONE=Asia/Kolkata
